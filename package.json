{
  "name": "wg-data-fetcher",
  "version": "0.1.0",
  "description": "CLI tool to fetch World of Tanks data from the Wargaming API",
  "type": "module",
  "bin": {
    "wg-fetcher": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write src tests"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
