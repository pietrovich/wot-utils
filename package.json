{
  "name": "@pietrovich/wot-utils",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "repository": "github:pietrovich/wot-utils",
  "version": "0.2.2",
  "description": "CLI utilities for World of Tanks data and assets",
  "type": "module",
  "bin": {
    "pie-wot": "dist/index.js"
  },
  "files": [
    "./.env.example",
    "./dist",
    "./scripts"
  ],
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.*'",
    "test:integration": "vitest run integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src tests",
    "lint:fix": "eslint --fix src tests",
    "format:check": "prettier --check src tests",
    "format:fix": "prettier --write src tests",
    "qa": "npm run lint && npm run format:check && npm run test:coverage"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3",
    "json5": "^2.2.3",
    "maxrects-packer": "^2.7.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
